# Firebase Configuration (client-side)
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# Backend API URL (defaults to localhost:5000 in development)
VITE_API_URL=http://localhost:5000/api/v1

# Google Calendar OAuth 2.0 Client ID
# Obtain from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Make sure to add your app origin to the "Authorized JavaScript origins" list
# and set the redirect URI to: <your-origin>/google-callback.html
VITE_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
