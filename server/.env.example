# Firebase Configuration
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="your-service-account-email"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# AI Service Keys
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_KEY_2="your-gemini-api-key-2-for-scanning"
GROQ_API_KEY="your-groq-api-key"
GROQ_API_KEY_2="your-groq-api-key-2"
GROQ_API_KEY_3="your-groq-api-key-3"
CEREBRAS_API_KEY="your-cerebras-api-key"  # Optional: enables fast 120B model for complex tasks
Z_AI_API_KEY="your-z-ai-api-key"             # Optional: enables GLM-4.7-Flash as fallback
CLOUDFLARE_API_KEY="your-cloudflare-api-key" # Used for scan feature (Llama 3.2 Vision)
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
PORT=5000
NODE_ENV="development"

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Both values come from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# GOOGLE_CLIENT_ID   — same value as VITE_GOOGLE_CLIENT_ID in the frontend (.env.local)
# GOOGLE_CLIENT_SECRET — SERVER-ONLY. Never expose this to the frontend.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
