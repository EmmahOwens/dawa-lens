# Admin App — Firebase Configuration (same project as the main app)
# Copy this file to .env.local and fill in your values from:
# Firebase Console → Project Settings → General → Your Apps → Web App

VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="medicine-d3ba2.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="medicine-d3ba2"
VITE_FIREBASE_STORAGE_BUCKET="medicine-d3ba2.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# Backend API URL
VITE_API_URL=http://localhost:5000/api/v1
